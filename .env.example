# ===========================================
# Flarenet Backend Environment Variables
# ===========================================
# Copy this file to .env and fill in your values
# For Docker local dev, these are set in compose/docker-compose.yml

# -----------------
# Node Environment
# -----------------
NODE_ENV=development

# -----------------
# Database (PostgreSQL)
# -----------------
# Local Docker: postgresql://postgres:postgres@postgres:5432/flarenet
# Production: Your managed database URL
DATABASE_URL=postgresql://user:password@host:5432/database

# -----------------
# Redis
# -----------------
# Local Docker: redis://redis:6379
# Production (Redis Cloud/ElastiCache): redis://user:password@host:port
REDIS_URL=redis://localhost:6379
REDIS_ENABLED=true
# Optional for cloud Redis
# REDIS_USE_TLS=true

# -----------------
# ClickHouse
# -----------------
# Local Docker: http://clickhouse:8123
CH_URI=http://localhost:8123
CH_USERNAME=default
CH_PASS=default
CLICKHOUSE_HOST=localhost
CLICKHOUSE_PORT=8123

# -----------------
# Kafka
# -----------------
# Local Docker: kafka:9092
# Production (MSK/Confluent): your-kafka-broker:9092
KAFKA_BROKER=localhost:9092

# -----------------
# LLM / AI Features (Optional)
# -----------------
# Get your API key from https://console.groq.com/
GROQ_API_KEY=

# -----------------
# GitHub OAuth (Optional)
# -----------------
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_REDIRECT_URI=http://localhost:5000/api/github/callback

# -----------------
# Frontend URL (for OAuth redirects)
# -----------------
FRONTEND_URL=http://localhost:3000

# -----------------
# JWT
# -----------------
JWT_SECRET=

# -----------------
# Encryption (32 characters required)
# -----------------
SECRET_KEY=

# -----------------
# AWS (Optional - for deployments)
# -----------------
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=
S3_BUCKET=
